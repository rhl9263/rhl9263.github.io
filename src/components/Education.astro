---
import { education } from '../config';
---

<section id="education" class="section animate-on-scroll">
  <header class="section__header">
    <span class="section__eyebrow">Education</span>
    <h2 class="section__title">Academic foundation.</h2>
  </header>

  <ol class="education-list" role="list">
    {education.map((edu) => (
      <li class="education-item">
        <div class="education-item__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/>
          </svg>
        </div>
        <div class="education-item__body">
          <h3 class="education-item__school">{edu.institution}</h3>
          <p class="education-item__degree">{edu.degree}</p>
          <div class="education-item__meta">
            <span class="education-item__grade">{edu.grade}</span>
            <span class="education-item__sep">·</span>
            <span class="education-item__location">{edu.location}</span>
            <span class="education-item__sep">·</span>
            <span class="education-item__date">{edu.from} — {edu.to}</span>
          </div>
        </div>
      </li>
    ))}
  </ol>
</section>
